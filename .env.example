VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Optional nur fuer aeltere Supabase-Projekte:
# VITE_SUPABASE_ANON_KEY=your-legacy-anon-key

# Invite-E-Mails laufen serverseitig ueber die Supabase Edge Function `send-family-invite`.
# Die noetigen Secrets werden direkt in Supabase gesetzt, nicht in diese .env-Datei:
# supabase secrets set RESEND_API_KEY=... FAMILY_INVITE_FROM_EMAIL=... INVITE_APP_URL=https://your-app-url
# Hinweis: SUPABASE_SERVICE_ROLE_KEY ist in gehosteten Supabase Edge Functions bereits als Default Secret vorhanden.